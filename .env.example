# ===== Database =====
# Local dev (matches docker-compose.yml):
DATABASE_URL="mysql://yugioh_user:yugioh_pass@localhost:3306/yugioh_db"

# Production (example — replace passwords, and host should be the MySQL container
# hostname inside docker-compose.prod.yml, e.g. "mysql"):
# DATABASE_URL="mysql://yugioh_user:CHANGE_ME@mysql:3306/yugioh_db?connection_limit=10&pool_timeout=20"

# ===== MySQL container (used by docker-compose.prod.yml) =====
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT
MYSQL_DATABASE=yugioh_db
MYSQL_USER=yugioh_user
MYSQL_PASSWORD=CHANGE_ME_APP

# ===== App runtime =====
# Public URL the app is served from — required by SvelteKit for correct
# origin checking and redirect generation behind a reverse proxy.
ORIGIN=https://your-domain.example
# Trust X-Forwarded-* headers from Caddy/Nginx:
PROTOCOL_HEADER=x-forwarded-proto
HOST_HEADER=x-forwarded-host
BODY_SIZE_LIMIT=512K
# Port the Node server listens on inside the container:
PORT=3000

# ===== Caddy =====
# Domain Caddy will issue certs for and proxy to the app:
CADDY_DOMAIN=your-domain.example
