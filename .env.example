# ===== Database =====
# Local dev (matches docker-compose.yml):
DATABASE_URL="mysql://yugioh_user:yugioh_pass@localhost:3306/yugioh_db"

# Production (example — replace password; host is the MySQL container
# hostname inside docker-compose.prod.yml, i.e. "mysql"):
# DATABASE_URL="mysql://yugioh_user:CHANGE_ME@mysql:3306/yugioh_db?connection_limit=10&pool_timeout=20"

# ===== MySQL container (docker-compose.prod.yml) =====
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT
MYSQL_DATABASE=yugioh_db
MYSQL_USER=yugioh_user
MYSQL_PASSWORD=CHANGE_ME_APP

# ===== App runtime =====
# Public URL the app is served from. Dalang edge terminates HTTPS and
# forwards HTTP to port 80 on the VPS. The app itself listens on port
# 3000 inside the container; Docker maps host:80 -> container:3000.
# ORIGIN MUST be the public https:// URL so SvelteKit's origin check
# and redirect helpers work behind the edge.
ORIGIN=https://50e5d6dc-6f31-4fb8-86f1-55830f9c8e04.svc.dalang.io

# Trust X-Forwarded-* headers set by Dalang edge so SvelteKit
# reconstructs the correct scheme + host inside load functions.
PROTOCOL_HEADER=x-forwarded-proto
HOST_HEADER=x-forwarded-host

BODY_SIZE_LIMIT=512K
PORT=3000
